# Frontend (Vite) — this repo's own Supabase project.
# Public/anon values, safe to expose to the browser (RLS enforces access control).
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Frontend (Vite) — EVIONOR's Supabase project. Admin users authenticate directly
# against this project. Anon key only, RLS/roles enforce access control server-side.
VITE_EVIONOR_SUPABASE_URL=
VITE_EVIONOR_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# The variables below are NOT read from .env — they are edge function secrets,
# configured in the Supabase project's dashboard (Project Settings > Edge
# Functions > Secrets), not in this file. Listed here so the required set is
# documented in one place.
#
# SUPABASE_URL                    this repo's own Supabase project URL
# SUPABASE_SERVICE_ROLE_KEY       this repo's own Supabase service-role key
# EVIONOR_SUPABASE_URL            EVIONOR's Supabase project URL
# EVIONOR_SUPABASE_ANON_KEY       EVIONOR's Supabase anon key
# EVIONOR_SUPABASE_SERVICE_KEY    EVIONOR's Supabase service-role key
# RESEND_API_KEY                  Resend API key used to send offer emails
# ---------------------------------------------------------------------------
